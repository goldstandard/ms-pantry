# Zkopíruj tento soubor jako .env.local a doplň hodnoty ze Supabase projektu.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Volitelné: Go-UPC API klíč (https://go-upc.com → Dashboard → API Key)
# Bez tohoto klíče se Go-UPC jako třetí fallback při hledání čárových kódů přeskočí.
# VITE_GO_UPC_KEY=your-go-upc-key
