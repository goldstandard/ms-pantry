# Zkopíruj tento soubor jako .env.local a doplň hodnoty ze Supabase projektu.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Go-UPC API klíč není frontend proměnná — ukládá se jako Supabase secret:
#   supabase secrets set GO_UPC_KEY=tvuj-klic
#   supabase functions deploy upc-lookup
